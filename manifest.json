{
  "key": "",
  "manifest_version": 3,
  "name": "AI Tool Agent",
  "version": "3.0.0",
  "description": "为 AI 网页版添加本地工具调用能力 - 支持 DeepSeek/ChatGPT/Kimi/通义千问/智谱/豆包",
  "permissions": [
    "activeTab",
    "storage",
    "nativeMessaging",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://kimi.com/*",
    "https://www.kimi.com/*",
    "https://kimi.moonshot.cn/*",
    "https://tongyi.aliyun.com/*",
    "https://qianwen.aliyun.com/*",
    "https://chat2.qianwen.com/*",
    "https://chat.qwen.ai/*",
    "https://www.qianwen.com/*",
    "https://qianwen.com/*",
    "https://chatglm.cn/*",
    "https://chat.z.ai/*",
    "https://z.ai/*",
    "https://www.doubao.com/*",
    "https://doubao.com/*",
    "http://localhost:3002/*",
    "http://127.0.0.1:3002/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://kimi.com/*",
        "https://www.kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://tongyi.aliyun.com/*",
        "https://qianwen.aliyun.com/*",
        "https://chat2.qianwen.com/*",
        "https://chat.qwen.ai/*",
        "https://www.qianwen.com/*",
        "https://qianwen.com/*",
        "https://chatglm.cn/*",
        "https://chat.z.ai/*",
        "https://z.ai/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*"
      ],
      "js": ["src/platforms/platform-registry.js", "src/platforms/deepseek.js", "src/platforms/chatgpt.js", "src/platforms/kimi.js", "src/platforms/qwen.js", "src/platforms/qwen-intl.js", "src/platforms/chatglm.js", "src/platforms/zai.js", "src/platforms/doubao.js", "src/sse-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://kimi.com/*",
        "https://www.kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://tongyi.aliyun.com/*",
        "https://qianwen.aliyun.com/*",
        "https://chat2.qianwen.com/*",
        "https://chat.qwen.ai/*",
        "https://www.qianwen.com/*",
        "https://qianwen.com/*",
        "https://chatglm.cn/*",
        "https://chat.z.ai/*",
        "https://z.ai/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*"
      ],
      "js": [
        "src/core/state.js",
        "src/core/config.js",
        "src/core/logger.js",
        "src/core/tool-call-parser.js",
        "src/core/parser.js",
        "src/core/executor.js",
        "src/core/backfill.js",
        "src/platforms/platform-registry.js",
        "src/platforms/deepseek.js",
        "src/platforms/chatgpt.js",
        "src/platforms/kimi.js",
        "src/platforms/qwen.js",
        "src/platforms/qwen-intl.js",
        "src/platforms/chatglm.js",
        "src/platforms/zai.js",
        "src/platforms/doubao.js",
        "src/dom/input.js",
        "src/dom/ai-message.js",
        "src/tools/registry.js",
        "src/tools/builtin.js",
        "src/plugins/loader.js",
        "src/gateway/bridge.js",
        "src/ui/connection.js",
        "src/ui/file-browser.js",
        "src/ui/panel-css.js",
        "src/ui/panel.js",
        "src/ui/actions.js",
        "src/monitor/input-monitor.js",
        "src/router.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/injected.js"],
      "matches": [
        "https://chat.deepseek.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://kimi.com/*",
        "https://www.kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://tongyi.aliyun.com/*",
        "https://qianwen.aliyun.com/*",
        "https://chat2.qianwen.com/*",
        "https://chat.qwen.ai/*",
        "https://www.qianwen.com/*",
        "https://qianwen.com/*",
        "https://chatglm.cn/*",
        "https://chat.z.ai/*",
        "https://z.ai/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Tool Agent"
  }
}